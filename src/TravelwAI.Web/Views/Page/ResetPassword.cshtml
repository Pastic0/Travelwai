@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
    <link rel="stylesheet" href="/css/login_signup_style.css?v=2026-06-29-guide-google-wiki-v40" />
    <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-06-29-guide-google-wiki-v40" />
  </head>
  <body onload="initResetPasswordPage()">
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    <h1 class="title">
      <a class="brand-home-link" href="/landing" aria-label="Về Landing Page TravelwAI">
        <img
          src="/logo/travelwai-paper-plane.png"
          alt="TravelwAI Logo"
          style="height: 50px; margin-right: 10px"
        />
        <span>TravelwAI</span>
      </a>
    </h1>
    <p class="auth-page-subtitle">Tạo mật khẩu mới an toàn để tiếp tục sử dụng các tính năng TravelwAI.</p>

    <div class="container">
      <div class="login-container password-reset-card">
        <p class="auth-kicker">Đổi mật khẩu</p>
        <h2 class="login-title">Tạo mật khẩu mới</h2>
        
        <form class="login-form" id="resetPasswordForm" onsubmit="handleResetPassword(event)">
          <input
            type="password"
            id="newPassword"
            placeholder="Mật khẩu mới"
            minlength="6"
            required
          />
          <input
            type="password"
            id="confirmNewPassword"
            placeholder="Nhập lại mật khẩu mới"
            minlength="6"
            required
          />
          <button type="submit" class="login-btn">Đổi mật khẩu</button>
        </form>

        <p class="auth-message" id="authMessage" hidden></p>

        <p class="login-text">
          Quay lại
          <a href="/login" class="login-link">Đăng nhập</a>
        </p>
      </div>
      <div class="photos-container">
        <div class="polaroid" style="transform: rotate(-6deg)">
          <img src="/login_signup_image/2.png" alt="Hà Nội" />
        </div>
        <div class="polaroid featured" style="z-index: 3">
          <img src="/login_signup_image/1.png" alt="Sài Gòn" />
        </div>
        <div class="polaroid" style="transform: rotate(5deg)">
          <img src="/login_signup_image/3.png" alt="Đà Nẵng" />
        </div>
      </div>
    </div>
    <script src="/script/accounts.js?v=2026-06-29-guide-google-wiki-v40"></script>
      <script src="/script/travelwai_guide_chatbot.js?v=2026-06-29-guide-google-wiki-v40"></script>
<script src="/script/theme_toggle.js?v=2026-06-29-guide-google-wiki-v40"></script>
</body>
</html>

