@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nhắn tin - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />



    <link rel="stylesheet" href="css/main_site_style.css?v=2026-07-01-clean-v1" />
    <link rel="stylesheet" href="css/messaging_style.css?v=2026-07-01-clean-v1" />
    <link rel="stylesheet" href="/css/travelwai_nav_contact.css?v=2026-07-01-clean-v1" />
<link rel="stylesheet" href="/css/travelwai_font.css?v=2026-07-01-clean-v1" />
</head>
  <body class="messaging-page">
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    <div class="background-slider"></div>

    @await Html.PartialAsync("~/Views/Shared/_TravelwAINav.cshtml", "messaging")

    <main class="messaging-container">
      <div class="messaging-layout">
        <!-- Thanh bên trò chuyện -->
        <div class="chat-sidebar">
          <div class="sidebar-header">
            <!-- Friend Request Section (appears when there are requests) -->
            <!-- Add Friend Search Section -->
            <div class="friend-search-section">
              <div class="friend-search-title-row">
                <h2>Thêm bạn bè</h2>
                <div class="friend-title-actions">
                  <button
                    type="button"
                    class="sidebar-mode-toggle-btn icon-btn"
                    id="createGroupChatBtn"
                    onclick="openGroupChatModal()"
                    aria-label="Tạo nhóm trò chuyện"
                    title="Tạo nhóm"
                  >
                    <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                      <path d="M18 8h4" />
                      <path d="M20 6v4" />
                    </svg>
                    <span class="sr-only">Tạo nhóm</span>
                  </button>
                  <button
                    type="button"
                    class="sidebar-mode-toggle-btn icon-btn"
                    id="sidebarModeToggleBtn"
                    onclick="toggleSidebarPanelMode()"
                    aria-label="Chuyển danh sách cuộc trò chuyện sang danh sách bạn bè"
                    title="Xem bạn bè"
                  >
                    <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    <span class="sr-only">Xem bạn bè</span>
                  </button>
                </div>
              </div>
              <input
                type="text"
                id="searchFriendInput"
                placeholder="Tìm kiếm người dùng"
                oninput="searchUsers()"
              />
              <div
                class="friend-search-results-container"
                id="friendSearchResultsContainer"
              >
                <!-- Friend search results will appear here -->
              </div>
            </div>
            <!-- End Add Friend Search Section -->

          </div>


          <div class="search-container">
            <input
              type="text"
              id="searchConversations"
              placeholder="Tìm kiếm cuộc trò chuyện..."
            />
          </div>

          <div class="conversation-list" id="conversationList">
            <div class="loading-message">Đang tải cuộc trò chuyện...</div>
          </div>
        </div>

        <div
          class="chat-width-resizer"
          id="chatWidthResizer"
          role="separator"
          aria-orientation="vertical"
          aria-label="Kéo trái phải để chỉnh khung chat"
          title="Kéo trái phải để chỉnh khung chat"
        ></div>

        <!-- Khu vực trò chuyện -->
        <div class="chat-main">
          <div class="welcome-screen" id="welcomeScreen">
            <div class="welcome-content">
              <h3>Nhắn tin</h3>
              <div class="welcome-actions">
                <button class="start-chat-btn" onclick="openNewChatModal()">
                  Tìm bạn bè
                </button>
                <button class="start-chat-btn" onclick="openShareMemoryModal()">
                  Chia sẻ kỷ niệm
                </button>
              </div>
            </div>
          </div>

          <!-- Conversation Header -->
          <div
            class="conversation-header"
            id="conversationHeader"
            style="display: none"
          >
            <div class="conversation-user-info">
              <div class="user-avatar">
                <img
                  id="conversationUserAvatar"
                  src="logo/profile-icon-white.png"
                  alt="Người dùng"
                />
              </div>
              <div class="user-details">
                <h3 id="conversationUserName">Tên người dùng</h3>
                <p id="conversationUserStatus" class="user-status offline">offline</p>
              </div>
            </div>
            <div class="conversation-actions">
              <button class="action-btn icon-btn conversation-name-action-btn" id="conversationNameBtn" onclick="openConversationNameEditor()" aria-label="Đặt biệt danh" title="Đặt biệt danh" hidden>
                <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 20h9" />
                  <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                </svg>
                <span class="sr-only">Đặt biệt danh</span>
              </button>
              <button class="action-btn icon-btn remove-friend-action-btn" id="removeFriendBtn" onclick="removeFriendFromCurrentConversation()" aria-label="Xóa bạn bè" title="Xóa bạn bè">
                <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M22 11h-6" />
                </svg>
                <span class="sr-only">Xóa bạn bè</span>
              </button>
              <button class="action-btn icon-btn clear-conversation-action-btn" onclick="clearConversation()" aria-label="Xóa cuộc trò chuyện" title="Xóa cuộc trò chuyện">
                <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M3 6h18" />
                  <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                  <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                  <path d="M10 11v6" />
                  <path d="M14 11v6" />
                </svg>
                <span class="sr-only">Xóa cuộc trò chuyện</span>
              </button>
              <button class="action-btn icon-btn clear-conversation-action-btn" id="closeConversationBtn" onclick="closeCurrentConversation()" aria-label="Đóng cuộc trò chuyện" title="Đóng cuộc trò chuyện">
                <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18 6 6 18" />
                  <path d="m6 6 12 12" />
                </svg>
                <span class="sr-only">Đóng cuộc trò chuyện</span>
              </button>
            </div>
          </div>
          <div
            class="messages-container"
            id="messagesContainer"
            style="display: none"
          >
            <div class="messages-list" id="messagesList">
              <!-- Messages will be loaded here -->
            </div>
          </div>

          <!-- Ô nhập tin nhắn -->
          <div
            class="message-input-container"
            id="messageInputContainer"
            style="display: none"
          >
            <div class="message-input">
              <input
                type="file"
                id="chatAttachmentInput"
                class="file-input-hidden"
                accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.zip"
                onchange="handleChatAttachmentChange(event)"
              />
              <input
                type="text"
                id="messageInput"
                placeholder="Nhập tin nhắn..."
                onkeypress="handleMessageKeyPress(event)"
              />
              <button class="attachment-btn icon-btn" type="button" onclick="handleAttachment()" aria-label="Đính kèm tệp" title="Đính kèm tệp">
                <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                </svg>
              </button>
              <button class="send-btn" onclick="sendMessage()">Gửi</button>
            </div>
            <div class="chat-attachment-preview" id="chatAttachmentPreview" hidden>
              <span class="attachment-name" id="chatAttachmentName">Chưa chọn tệp</span>
              <button type="button" class="clear-attachment-btn" onclick="clearChatAttachment()">Bỏ chọn</button>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Hộp thoại cuộc trò chuyện mới -->
    <div class="modal" id="newChatModal">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Tạo cuộc trò chuyện mới</h3>
          <button class="close-btn" onclick="closeNewChatModal()">
            &times;
          </button>
        </div>
        <div class="modal-body">
          <div class="search-users-container">
            <input
              type="text"
              id="searchUsers"
              placeholder="Nhập email hoặc tên người dùng..."
              oninput="searchUsers()"
            />
          </div>
          <div class="users-list" id="usersList">
            <div class="loading-message">
              Nhập email hoặc tên để tìm kiếm người dùng...
            </div>
          </div>
          <div class="group-selection-panel" id="groupSelectionPanel" hidden>
            <div class="group-selection-summary" id="groupSelectionSummary">Chưa chọn người nhận</div>
            <button type="button" class="btn btn-primary" id="groupCreateBtn" onclick="handleSelectedChatUsers()">Nhắn tin</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Chia sẻ kỷ niệm Modal (Memory Panel) -->
    <div class="modal" id="shareMemoryModal">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Chia sẻ kỷ niệm</h3>
          <button class="close-btn" onclick="closeShareMemoryModal()">
            &times;
          </button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label for="memoryFile">Chọn kỷ niệm (ảnh, video, tài liệu...):</label>
            <input
              type="file"
              id="memoryFile"
              name="memoryFile"
              class="file-input-hidden"
              accept="image/*,video/*,.pdf,.doc,.docx,.txt"
              onchange="updateSelectedMemoryFile(event)"
            />
            <label for="memoryFile" class="file-dropzone file-dropzone-icon" title="Đính kèm tệp" aria-label="Đính kèm tệp">
              <span class="file-dropzone-title" aria-hidden="true">📎</span>
              <span class="file-dropzone-subtitle">Ảnh, video, PDF, Word hoặc TXT</span>
            </label>
            <div class="selected-file-card" id="selectedMemoryFile" hidden>
              <span class="selected-file-name" id="selectedMemoryFileName">Chưa chọn tệp</span>
              <button type="button" class="clear-attachment-btn" onclick="resetMemoryFileSelection()">Bỏ chọn</button>
            </div>
          </div>
          <div class="form-group search-users-container">
            <label for="shareWithUserEmail">Chia sẻ với email:</label>
            <input
              type="text"
              id="shareWithUserEmail"
              placeholder="Nhập email người nhận..."
              oninput="searchUsersForSharing()"
            />
            <div class="search-instructions">
              Nhập email người bạn muốn chia sẻ.
            </div>
          </div>
          <div class="users-list" id="shareUserSuggestionList">
            <div class="loading-message">Nhập email để tìm người dùng.</div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-primary" onclick="handleShareMemory()">
            Chia sẻ kỷ niệm
          </button>
        </div>
      </div>
    </div>

    <div class="loading-overlay" id="loadingOverlay" style="display: none">
      <div class="spinner"></div>
      <p>Đang tải...</p>
    </div>

    <div class="modal" id="friendDetailModal">
      <div class="modal-content friend-detail-modal-content">
        <div class="modal-header">
          <h3>Thông tin người dùng</h3>
          <button class="close-btn" onclick="closeFriendDetailModal()">
            &times;
          </button>
        </div>
        <div class="modal-body friend-detail-modal-body">
          <div class="friend-detail-avatar-container">
            <img
              id="friendDetailAvatar"
              src="logo/profile-icon-white.png"
              alt="Ảnh đại diện"
              class="friend-detail-avatar-img"
            />
            <div
              id="friendDetailAvatarInitial"
              class="friend-detail-avatar-initial"
              style="display: none"
            >
              ?
            </div>
          </div>
          <h4 id="friendDetailUsername">Tên người dùng</h4>
          <p id="friendDetailEmail" class="friend-detail-email-text">
            email@@example.com
          </p>
          <button
            id="friendDetailAddBtn"
            class="btn btn-primary add-friend-detail-btn"
            onclick=""
          >
            Thêm bạn bè
          </button>
          <p
            id="friendDetailStatusMsg"
            class="friend-detail-status"
            style="display: none"
          ></p>
        </div>
      </div>
    </div>

    <!-- Bảng yêu cầu kết bạn -->
    <!-- Friend Request Panel (Add this at the end of the body) -->
    <div class="friend-request-panel" id="friendRequestPanel">
      <div class="panel-header">
        <h3>Yêu cầu kết bạn</h3>
        <button class="close-panel-btn" id="closeFriendRequestPanelBtn">
          &times;
        </button>
      </div>
      <div class="panel-body" id="friendRequestListContainer">
        <div class="friend-request-item">
          <div class="request-item-avatar">
            <img src="logo/profile-icon-white.png" alt="Người dùng">
          </div>
          <div class="request-item-info">
            <div class="request-item-name">Tên người dùng</div>
            <div class="request-item-email">user@@example.com</div>
          </div>
          <div class="request-item-actions">
            <button class="btn-accept">Chấp nhận</button>
            <button class="btn-decline">Từ chối</button>
          </div>
        </div>
        <div class="loading-message" id="friendRequestPanelLoadingMsg">
          Đang tải yêu cầu...
        </div>
      </div>
    </div>

    <script src="script/accounts.js?v=2026-07-01-clean-v1"></script>
    <script src="script/vietnam_provinces.js?v=2026-07-01-clean-v1"></script>
    <script src="/script/image_upload_optimizer.js?v=2026-07-01-clean-v1"></script>
<script src="script/messaging_script.js?v=2026-07-01-clean-v1"></script>
    <script src="/script/travelwai_contact_panel.js?v=2026-07-01-clean-v1"></script>
    <script src="/script/travelwai_notification_panel.js?v=2026-07-01-clean-v1"></script>
      <script src="/script/theme_toggle.js?v=2026-07-01-clean-v1"></script>
</body>
</html>
