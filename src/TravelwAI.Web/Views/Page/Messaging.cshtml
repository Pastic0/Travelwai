@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nhắn tin - TravelwAI</title>
  <link rel="icon" href="/logo/travelwai-paper-plane.webp" type="image/webp" />
  <link rel="preload" as="image" href="/main_site_image/travelwai-bg-light.webp" />
  <link rel="stylesheet" href="/css/main_site_style.css?v=2026-06-24-contact-ai-v2" />
  <link rel="stylesheet" href="/css/messaging_style.css?v=2026-06-24-contact-ai-v2" />
  <link rel="stylesheet" href="/css/travelwai_nav_contact.css?v=2026-06-24-contact-ai-v2" />
  <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-06-24-contact-ai-v2" />
</head>
<body class="messaging-page">
  <div class="background-slider"></div>
  @await Html.PartialAsync("~/Views/Shared/_TravelwAINav.cshtml", "messaging")

  <main class="messaging-container">
    <div class="messaging-layout">
      <aside class="chat-sidebar">
        <div class="sidebar-header">
          <div class="friend-search-section">
            <div class="friend-search-title-row">
              <h2>Thêm bạn bè</h2>
              <div class="friend-title-actions">
                <button type="button" class="sidebar-mode-toggle-btn icon-btn" id="createGroupChatBtn" onclick="openGroupChatModal()" aria-label="Tạo nhóm trò chuyện" title="Tạo nhóm"><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M18 8h4"/><path d="M20 6v4"/></svg><span class="sr-only">Tạo nhóm</span></button>
                <button type="button" class="sidebar-mode-toggle-btn icon-btn" id="sidebarModeToggleBtn" onclick="toggleSidebarPanelMode()" aria-label="Chuyển danh sách cuộc trò chuyện sang danh sách bạn bè" title="Xem bạn bè"><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><span class="sr-only">Xem bạn bè</span></button>
              </div>
            </div>
            <input type="text" id="searchFriendInput" placeholder="Tìm kiếm người dùng" oninput="searchUsers()" />
            <div class="friend-search-results-container" id="friendSearchResultsContainer"></div>
          </div>
        </div>
        <div class="search-container"><input type="text" id="searchConversations" placeholder="Tìm kiếm cuộc trò chuyện..." /></div>
        <div class="conversation-list" id="conversationList"><div class="loading-message">Đang tải cuộc trò chuyện...</div></div>
        <div class="conversation-list friends-list" id="friendsList" style="display:none"></div>
      </aside>

      <div class="chat-width-resizer" id="chatWidthResizer" role="separator" aria-orientation="vertical" aria-label="Kéo trái phải để chỉnh khung chat" title="Kéo trái phải để chỉnh khung chat"></div>

      <section class="chat-main">
        <div class="welcome-screen" id="welcomeScreen"><div class="welcome-content"><h3>Nhắn tin</h3><div class="welcome-actions"><button class="start-chat-btn" onclick="openNewChatModal()">Tìm bạn bè</button><button class="start-chat-btn" onclick="openShareMemoryModal()">Chia sẻ kỷ niệm</button></div></div></div>
        <div class="conversation-header" id="conversationHeader" style="display:none">
          <div class="conversation-user-info"><div class="user-avatar"><img id="conversationUserAvatar" src="/logo/profile-icon-white.webp" alt="Người dùng" /></div><div class="user-details"><h3 id="conversationUserName">Tên người dùng</h3><p id="conversationUserStatus" class="user-status offline">offline</p></div></div>
          <div class="conversation-actions">
            <button class="action-btn icon-btn conversation-name-action-btn" id="conversationNameBtn" onclick="openConversationNameEditor()" aria-label="Đặt biệt danh" title="Đặt biệt danh" hidden><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg><span class="sr-only">Đặt biệt danh</span></button>
            <button class="action-btn icon-btn remove-friend-action-btn" id="removeFriendBtn" onclick="removeFriendFromCurrentConversation()" aria-label="Xóa bạn bè" title="Xóa bạn bè"><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11h-6"/></svg><span class="sr-only">Xóa bạn bè</span></button>
            <button class="action-btn icon-btn clear-conversation-action-btn" onclick="clearConversation()" aria-label="Xóa cuộc trò chuyện" title="Xóa cuộc trò chuyện"><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg><span class="sr-only">Xóa cuộc trò chuyện</span></button>
            <button class="action-btn icon-btn clear-conversation-action-btn" id="closeConversationBtn" onclick="closeCurrentConversation()" aria-label="Đóng cuộc trò chuyện" title="Đóng cuộc trò chuyện"><svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg><span class="sr-only">Đóng cuộc trò chuyện</span></button>
          </div>
        </div>
        <div class="messages-container" id="messagesContainer" style="display:none"><div class="messages-list" id="messagesList"></div></div>
        <div class="message-input-container" id="messageInputContainer" style="display:none">
          <div class="message-input">
            <input type="file" id="chatAttachmentInput" class="file-input-hidden" accept="image/*,video/*,.pdf,.doc,.docx,.txt" onchange="handleChatAttachmentChange(event)" />
            <button type="button" class="attach-btn" onclick="handleAttachment()" aria-label="Đính kèm tệp">📎</button>
            <input type="text" id="messageInput" placeholder="Nhập tin nhắn..." onkeypress="handleMessageKeyPress(event)" autocomplete="off" />
            <button type="button" class="send-btn" onclick="sendMessage()">Gửi</button>
          </div>
          <div class="selected-file-card" id="chatAttachmentPreview" hidden><span id="chatAttachmentName">Chưa chọn tệp</span><button type="button" onclick="clearChatAttachment()">Bỏ chọn</button></div>
        </div>
      </section>
    </div>
  </main>

  <div class="modal" id="newChatModal">
    <div class="modal-content"><div class="modal-header"><h3>Tạo cuộc trò chuyện mới</h3><button class="close-btn" onclick="closeNewChatModal()">&times;</button></div><input type="text" id="searchUsers" placeholder="Nhập email hoặc tên để tìm kiếm người dùng..." oninput="searchUsers()" /><div id="groupSelectionPanel" class="group-selection-panel" hidden><div id="groupSelectionSummary">Chưa chọn người nhận</div><button id="groupCreateBtn" type="button" onclick="handleSelectedChatUsers()">Tạo nhóm</button></div><div id="usersList" class="users-list"><div class="loading-message">Nhập email hoặc tên để tìm kiếm người dùng...</div></div></div>
  </div>

  <div class="modal" id="shareMemoryModal">
    <div class="modal-content"><div class="modal-header"><h3>Chia sẻ kỷ niệm</h3><button class="close-btn" onclick="closeShareMemoryModal()">&times;</button></div><label>Chọn kỷ niệm</label><input type="file" id="memoryFile" onchange="updateSelectedMemoryFile(event)" /><small>Ảnh, video, PDF, Word hoặc TXT</small><div class="selected-file-card" id="selectedMemoryFile" hidden><span id="selectedMemoryFileName">Chưa chọn tệp</span><button type="button" onclick="resetMemoryFileSelection()">Bỏ chọn</button></div><label>Chia sẻ với email:</label><input type="text" id="shareWithUserEmail" placeholder="Nhập email người bạn muốn chia sẻ." oninput="searchUsersForSharing()" /><div id="shareUserSuggestionList" class="users-list"><div class="loading-message">Nhập email để tìm người dùng.</div></div><button class="start-chat-btn" type="button" onclick="handleShareMemory()">Chia sẻ kỷ niệm</button></div>
  </div>

  <div class="modal" id="friendDetailModal">
    <div class="modal-content friend-detail-card"><div class="modal-header"><h3>Thông tin người dùng</h3><button class="close-btn" onclick="closeFriendDetailModal()">&times;</button></div><div class="friend-detail-avatar-wrap"><img id="friendDetailAvatar" src="/logo/profile-icon-white.webp" alt="Ảnh đại diện" /><div id="friendDetailAvatarInitial" class="user-avatar-initial">?</div></div><h4 id="friendDetailUsername">Tên người dùng</h4><p id="friendDetailEmail">Email</p><div id="friendDetailStatusMsg" class="friend-detail-status"></div><button id="friendDetailAddBtn" class="start-chat-btn" type="button">Thêm bạn bè</button></div>
  </div>

  <div class="friend-request-block" id="friendRequestBlock" style="display:none"><div class="friend-request-header"><h3>Yêu cầu kết bạn</h3><button type="button" onclick="document.getElementById('friendRequestBlock').style.display='none'">&times;</button></div><div id="friendRequestList" class="friend-request-list"><div class="loading-message">Đang tải yêu cầu...</div></div></div>
  <div id="friendRequestListContainer" hidden></div>
  <div class="loading-overlay" id="loadingOverlay" style="display:none"><div>Đang tải...</div></div>

  <script src="/script/accounts.js?v=2026-06-24-contact-ai-v2"></script>
  <script src="/script/image_upload_optimizer.js?v=2026-06-24-contact-ai-v2"></script>
  <script src="/script/messaging_script.js?v=2026-06-24-contact-ai-v2"></script>
  <script src="/script/travelwai_contact_panel.js?v=2026-06-24-contact-ai-v2"></script>
  <script src="/script/travelwai_notification_panel.js?v=2026-06-24-contact-ai-v2"></script>
  <script src="/script/theme_toggle.js?v=2026-06-24-mini-nav-v4"></script>
</body>
</html>
