@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
    <link rel="stylesheet" href="css/login_signup_style.css?v=2026-07-01-clean-v1" />
    <script src="script/accounts.js?v=2026-07-01-clean-v1"></script>
  <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-07-02-final-optimize-v1" />
  </head>
  <body>
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    <h1 class="title">
      <a class="brand-home-link" href="/landing" aria-label="Về Landing Page TravelwAI">
        <img
          src="/logo/travelwai-paper-plane.png"
          alt="TravelwAI Logo"
          style="height: 50px; margin-right: 10px"
        />
        <span>TravelwAI</span>
      </a>
    </h1>

    <div class="container">
      <div class="login-container">
        <h2 class="login-title">Đăng nhập</h2>
        <form class="login-form" onsubmit="handleLogin(event)">
          <input type="text" id="email" placeholder="Email" required />
          <input
            type="password"
            id="password"
            placeholder="Mật khẩu"
            required
          />
          <button type="submit" class="login-btn">Đăng nhập</button>
        </form>
        <p class="signup-text">
          Chưa có tài khoản?
          <a href="/signup" class="signup-link">Đăng ký</a>
        </p>
        <p class="change-password">
          Quên mật khẩu?
          <a href="/forgot-password" class="signup-link">Đặt lại mật khẩu</a>
        </p>
      </div>

      <div class="photos-container">
        <div class="polaroid" style="transform: rotate(-6deg)">
          <img src="login_signup_image/2.png" alt="Hà Nội" />
        </div>
        <div class="polaroid featured" style="z-index: 3">
          <img src="login_signup_image/1.png" alt="Sài Gòn" />
        </div>
        <div class="polaroid" style="transform: rotate(5deg)">
          <img src="login_signup_image/3.png" alt="Đà Nẵng" />
        </div>
      </div>
    </div>
<script src="/script/theme_toggle.js?v=2026-07-02-final-optimize-v1"></script>
</body>
</html>

