      <input type="hidden" id="postMonth" />
      <div class="form-grid">
        <div class="form-group"><label>Lễ hội/ngày lễ</label><input id="postFestival" placeholder="Nhập lễ hội/ngày lễ rồi bấm AI" /></div>
        <div class="form-group"><label>Tiêu đề</label><input id="postTitle" placeholder="AI sẽ tự tạo từ Lễ hội/ngày lễ" /></div>
        <div class="form-group"><label>Tài khoản</label><select id="postAuthor" required><option value="">Chọn tài khoản</option></select></div>
        <div class="form-group"><label>Trạng thái</label><select id="postStatus"><option>Hiển thị</option><option>Ẩn</option></select></div>
        <div class="form-group"><label>Tỉnh thành</label><input id="postProvince" placeholder="Ví dụ: Huế, Hà Nội" /></div>
        <div class="form-group full"><label>Từ khóa tour</label><input id="postTourKeywords" placeholder="Ví dụ: Huế, Festival, di sản" /></div>
        <div class="form-group full"><label>Tóm tắt</label><textarea id="postSummary" rows="3"></textarea></div>
        <div class="form-group full"><label>Nội dung</label><div class="content-ai-field"><textarea id="postContent" rows="5"></textarea><button class="ai-content-button" id="postAiButton" type="button" formnovalidate title="Tạo tiêu đề, tóm tắt và nội dung văn hoá lịch sử thật từ lễ hội/ngày lễ" aria-label="Tạo tiêu đề, tóm tắt và nội dung văn hoá lịch sử bằng AI">✨</button></div></div>
        <div class="form-group full"><label>Ảnh minh hoạ</label><div class="image-url-field image-url-field-textarea"><textarea id="postImageUrls" rows="2" placeholder="Mỗi dòng một URL ảnh"></textarea><button class="image-upload-icon" id="postImageUploadButton" type="button" title="Đính kèm tệp ảnh" aria-label="Đính kèm tệp ảnh">📎</button><input id="postImageFiles" type="file" accept="image/*" multiple hidden /></div><small class="form-help">Nhập URL ảnh hoặc đính kèm ảnh bằng nút trong ô.</small><div class="post-image-preview" id="postImagePreview"></div></div>
      </div>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closePostModal()">Đóng</button>
        <button class="btn-primary" type="submit">Lưu bài viết</button>
      </div>
    </form>
