@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin TravelwAI</title>
  <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
  <link rel="stylesheet" href="/css/main_site_style.css?v=2026-06-28-admin-analytics-popup-text-v27" />
  <link rel="stylesheet" href="/css/travelwai_nav_contact.css?v=2026-06-28-admin-analytics-popup-text-v27" />
  <link rel="stylesheet" href="/css/tour_admin.css?v=2026-06-28-admin-analytics-popup-text-v27" />
<link rel="stylesheet" href="/css/travelwai_font.css?v=2026-06-28-admin-analytics-popup-text-v27" />
</head>
<body class="tour-admin-page admin-page" data-page="admin">
  @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
  @await Html.PartialAsync("~/Views/Shared/_TravelwAINav.cshtml", "admin")

  <main class="tour-admin-shell">
    <section class="tour-admin-hero">
      <div>
        <span class="eyebrow">Quản trị hệ thống</span>
        <h1>Admin TravelwAI</h1>
      </div>
      <div class="tour-actions page-hero-actions sales-hero-actions management-page-switcher" data-admin-page-switcher>
        <a class="btn-soft btn-page-link admin-role-page-link management-page-link is-current" href="/admin" style="display:none;text-decoration:none" aria-current="page">Admin</a>
        <a class="btn-soft btn-page-link admin-role-page-link management-page-link" href="/tour-sales" style="display:none;text-decoration:none">Sales</a>
        <a class="btn-soft btn-page-link admin-role-page-link management-page-link" href="/business" style="display:none;text-decoration:none">Business</a>
        <a class="btn-soft btn-page-link admin-role-page-link management-page-link" href="/manage" style="display:none;text-decoration:none">Manage</a>
      </div>
    </section>

    <section class="dashboard-grid">
      <article class="stat-card"><span>Tài khoản</span><strong id="adminStatAccounts">0</strong></article>
      <article class="stat-card"><span>Bị khóa</span><strong id="adminStatLocked">0</strong></article>
      <article class="stat-card"><span>Sales</span><strong id="adminStatSales">0</strong></article>
      <article class="stat-card"><span>Tour</span><strong id="adminStatTours">0</strong></article>
      <article class="stat-card"><span>Lịch trình</span><strong id="adminStatSchedules">0</strong></article>
      <article class="stat-card"><span>Trạng thái</span><strong id="adminStatPlanStatuses">0</strong></article>
      <article class="stat-card"><span>Tỉnh thành</span><strong id="adminStatProvinces">0</strong></article>
      <article class="stat-card"><span>Bài viết</span><strong id="adminStatPosts">0</strong></article>
    </section>

    <div class="tabs">
      <button class="tab-btn active" data-tab="accounts" type="button">Tài khoản</button>
      <button class="tab-btn" data-tab="account-plans" type="button">Gói tài khoản</button>
      <button class="tab-btn" data-tab="tours" type="button">Tour</button>
      <button class="tab-btn" data-tab="schedules" type="button">Lịch trình</button>
      <button class="tab-btn" data-tab="plan-statuses" type="button">Trạng thái</button>
      <button class="tab-btn" data-tab="province-tags" type="button">Tỉnh thành</button>
      <button class="tab-btn" data-tab="posts" type="button">Bài viết</button>
      <button class="tab-btn" data-tab="analytics" type="button">Thống kê</button>
    </div>

    <section class="management-panel admin-tab-panel" id="tab-accounts">
      <div class="panel-header-row">
        <div>
          <h2>Quản lý tài khoản</h2>
        </div>
        <div class="sales-list-actions admin-panel-search-actions admin-account-list-actions">
          <button class="btn-primary btn-add-tour btn-change-avatar" id="changeAiAvatarButton" type="button" title="Thay đổi avatar AI" aria-label="Thay đổi avatar AI">⚙️</button>
          <input id="aiAvatarFile" type="file" accept="image/*" hidden />
          <div class="tour-search-box tour-search-box-small">
            <input id="accountSearchInput" type="search" placeholder="Tìm tài khoản..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearAccountSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr>
              <th>Tài khoản</th>
              <th>Vai trò</th>
              <th>Trạng thái</th>
              <th>Ưu đãi</th>
              <th>Ngày tạo</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="accountTableBody"><tr><td colspan="6" class="empty-line">Đang tải...</td></tr></tbody>
        </table>
      </div>
    </section>


    <section class="management-panel admin-tab-panel" id="tab-account-plans" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Bảng giá</h2>
        </div>
      </div>
      <form id="accountPlanSettingsForm">
        <div class="table-wrap table-scroll-5">
          <table class="account-plan-settings-table">
            <thead>
              <tr>
                <th>Gói</th>
                <th>Giá</th>
                <th>Dòng phụ</th>
                <th>Quyền lợi</th>
                <th>Thu phí</th>
              </tr>
            </thead>
            <tbody id="accountPlanSettingsBody"><tr><td colspan="5" class="empty-line">Đang tải bảng giá...</td></tr></tbody>
          </table>
        </div>
        <div class="modal-actions">
          <button class="btn-primary" type="submit">Lưu bảng giá</button>
        </div>
      </form>
    </section>

    <section class="management-panel admin-tab-panel" id="tab-tours" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Quản lý tour</h2>
        </div>
        <div class="sales-list-actions admin-panel-search-actions admin-tour-list-actions">
          <button class="btn-primary btn-add-tour" type="button" onclick="openTourModal()">Thêm tour</button>
          <div class="tour-search-box tour-search-box-small">
            <input id="tourSearchInput" type="search" placeholder="Tìm tour..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearTourSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr>
              <th>Tour</th><th>Điểm đến</th><th>Thời gian</th><th>Giá</th><th>Chỗ</th><th>Trạng thái</th><th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="tourTableBody"><tr><td colspan="7" class="empty-line">Đang tải tour...</td></tr></tbody>
        </table>
      </div>
    </section>

    <section class="management-panel admin-tab-panel" id="tab-schedules" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Quản lý lịch trình</h2>
        </div>
        <div class="sales-list-actions admin-panel-search-actions admin-schedule-list-actions">
          <div class="tour-search-box tour-search-box-small">
            <input id="scheduleSearchInput" type="search" placeholder="Tìm lịch trình..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearScheduleSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr><th>Tên lịch trình</th><th>Người tạo</th><th>Thời gian</th><th>Trạng thái</th><th>Thao tác</th></tr>
          </thead>
          <tbody id="scheduleTableBody"><tr><td colspan="5" class="empty-line">Đang tải lịch trình...</td></tr></tbody>
        </table>
      </div>
    </section>

    <section class="management-panel admin-tab-panel" id="tab-plan-statuses" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Quản lý trạng thái kế hoạch</h2>
                  </div>
        <div class="sales-list-actions admin-panel-search-actions admin-plan-status-list-actions">
          <button class="btn-primary btn-admin-add-action" type="button" onclick="openPlanStatusOptionModal()">Thêm trạng thái</button>
          <button class="btn-primary btn-admin-add-action" type="button" onclick="openTravelTagModal()">Thêm tag</button>
          <div class="tour-search-box tour-search-box-small">
            <input id="planStatusSearchInput" type="search" placeholder="Tìm trạng thái..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearPlanStatusSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr><th>Trạng thái</th><th>Tag áp dụng</th><th>Cách khớp</th><th>Hiển thị</th><th>Thao tác</th></tr>
          </thead>
          <tbody id="planStatusTableBody"><tr><td colspan="5" class="empty-line">Đang tải trạng thái...</td></tr></tbody>
        </table>
      </div>
    </section>

    <section class="management-panel admin-tab-panel" id="tab-province-tags" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Thông tin tỉnh thành và tag du lịch</h2>
                  </div>
        <div class="sales-list-actions admin-panel-search-actions admin-province-list-actions">
          <div class="tour-search-box tour-search-box-small">
            <input id="provinceTagSearchInput" type="search" placeholder="Tìm tỉnh thành..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearProvinceTagSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr><th>Tỉnh/thành</th><th>Khu vực</th><th>Tag</th><th>Thao tác</th></tr>
          </thead>
          <tbody id="provinceTagTableBody"><tr><td colspan="4" class="empty-line">Đang tải tỉnh thành...</td></tr></tbody>
        </table>
      </div>
    </section>


    <section class="management-panel admin-tab-panel" id="tab-analytics" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Thống kê</h2>
        </div>
        <div class="sales-list-actions admin-panel-search-actions">
          <button class="btn-primary btn-admin-add-action" id="adminAnalyticsAiButton" type="button">AI thống kê</button>
          <button class="btn-soft btn-clear-tour-search" id="adminAnalyticsRefreshButton" type="button">Tải lại</button>
        </div>
      </div>

      <div class="admin-analytics-block">
        <h3>Thống kê tháng</h3>
        <div class="dashboard-grid admin-analytics-grid">
          <article class="stat-card admin-analytics-card" data-analytics-detail="province" role="button" tabindex="0"><span>Tỉnh được tìm nhiều nhất</span><strong id="analyticsMonthTopProvince">0</strong></article>
          <article class="stat-card admin-analytics-card" data-analytics-detail="budget" role="button" tabindex="0"><span>Ngân sách phổ biến</span><strong id="analyticsMonthBudgetRange">0</strong></article>
          <article class="stat-card admin-analytics-card" data-analytics-detail="tour" role="button" tabindex="0"><span>Loại tour đặt nhiều nhất</span><strong id="analyticsMonthTopTour">0</strong></article>
          <article class="stat-card admin-analytics-card" data-analytics-detail="group" role="button" tabindex="0"><span>Nhóm người dùng</span><strong id="analyticsMonthGroupSize">0</strong></article>
        </div>
      </div>

      <div class="admin-analytics-block">
        <h3>Thống kê năm theo từng tháng</h3>
        <div class="table-wrap table-scroll-5 admin-analytics-year-wrap">
          <table>
            <thead>
              <tr><th>Tháng</th><th>Tỉnh được tìm nhiều nhất</th><th>Ngân sách phổ biến</th><th>Loại tour đặt nhiều nhất</th><th>Nhóm người dùng</th></tr>
            </thead>
            <tbody id="analyticsYearMonthBody"><tr><td colspan="5" class="empty-line">Đang tải thống kê...</td></tr></tbody>
          </table>
        </div>
      </div>

      <div class="admin-analytics-ai-card" id="adminAnalyticsSummary">Bấm AI thống kê để tạo nhận xét.</div>
    </section>

    <section class="management-panel admin-tab-panel" id="tab-posts" style="display:none">
      <div class="panel-header-row">
        <div>
          <h2>Quản lý bài viết</h2>
        </div>
        <div class="sales-list-actions admin-panel-search-actions admin-post-list-actions">
          <button class="btn-primary btn-admin-add-action" type="button" onclick="openPostModal()">Thêm bài viết</button>
          <div class="tour-search-box tour-search-box-small">
            <input id="postSearchInput" type="search" placeholder="Tìm bài viết..." autocomplete="off" />
            <button class="btn-soft btn-clear-tour-search" id="clearAdminPostSearch" type="button">Xóa</button>
          </div>
        </div>
      </div>
      <div class="table-wrap table-scroll-5">
        <table>
          <thead>
            <tr><th>Bài viết</th><th>Tháng</th><th>Lễ hội</th><th>Tài khoản</th><th>Trạng thái</th><th>Thao tác</th></tr>
          </thead>
          <tbody id="postTableBody"><tr><td colspan="6" class="empty-line">Đang tải bài viết...</td></tr></tbody>
        </table>
      </div>
    </section>
  </main>

  <div class="form-modal" id="accountModal">
    <form class="form-card" id="accountForm">
      <h2>Sửa tài khoản</h2>
      <input type="hidden" id="accountId" />
      <div class="form-grid">
        <div class="form-group"><label>Email</label><input id="accountEmail" disabled /></div>
        <div class="form-group"><label>Tên hiển thị</label><input id="accountUsername" /></div>
        <div class="form-group full"><label>Vai trò</label><select id="accountRole"><option>Free</option><option>VIP</option><option>Premium</option><option>Sales</option><option>Business</option><option>Admin</option></select></div>
        <div class="form-group"><label>Hoa hồng</label><input id="accountCommissionPercent" type="number" min="0" max="100" step="1" /></div>
        <div class="form-group"><label>Cấp hoa hồng</label><select id="accountSalesLevel"><option value="1">Cấp 1</option><option value="2">Cấp 2</option><option value="3">Cấp 3</option><option value="4">Cấp 4</option><option value="5">Cấp 5</option></select></div>
        <div class="form-group"><label>Ưu đãi</label><input id="accountOfferDiscount" type="number" min="0" max="100" step="1" /></div>
        <div class="form-group"><label>Cấp ưu đãi</label><select id="accountOfferLevel"><option value="1">Cấp 1</option><option value="2">Cấp 2</option><option value="3">Cấp 3</option><option value="4">Cấp 4</option><option value="5">Cấp 5</option></select></div>
        <div class="form-group"><label>Dịch vụ</label><input id="accountServicePercent" type="number" min="0" max="100" step="1" /></div>
        <div class="form-group"><label>Cấp dịch vụ</label><select id="accountServiceLevel"><option value="1">Cấp 1</option><option value="2">Cấp 2</option><option value="3">Cấp 3</option><option value="4">Cấp 4</option><option value="5">Cấp 5</option></select></div>
        <div class="form-group full account-lock-group">
          <label class="account-lock-toggle" for="accountLocked">
            <input id="accountLocked" type="checkbox" />
            <span class="account-lock-box" aria-hidden="true"></span>
            <span class="account-lock-text">Khóa tài khoản</span>
          </label>
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closeAccountModal()">Đóng</button>
        <button class="btn-primary" type="submit">Lưu tài khoản</button>
      </div>
    </form>
  </div>

  <div class="form-modal" id="aiAvatarModal">
    <div class="form-card ai-avatar-card">
      <h2 class="ai-avatar-icon-title" title="Thay đổi avatar AI" aria-label="Thay đổi avatar AI">⚙️</h2>
      <div class="ai-avatar-actions">
        <button class="btn-primary btn-add-tour" type="button" onclick="chooseAiAvatar('travelwai')">Quản lý TravelwAI</button>
        <button class="btn-primary btn-add-tour" type="button" onclick="chooseAiAvatar('travelwinne')">Hướng dẫn viên Travelwinne</button>
      </div>
      <div class="ai-avatar-section-title">Cấu hình từng cấp</div>
      <form id="salesLevelSettingsForm">
        <div class="table-wrap sales-level-settings-wrap">
          <table class="sales-level-settings-table">
            <thead>
              <tr>
                <th>Cấp</th>
                <th>Ưu đãi</th>
                <th>Hoa hồng</th>
                <th>Dịch vụ</th>
              </tr>
            </thead>
            <tbody id="salesLevelSettingsGrid"></tbody>
          </table>
        </div>
        <div class="modal-actions">
          <button class="btn-primary" type="submit">Lưu cấu hình</button>
        </div>
      </form>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closeAiAvatarModal()">Đóng</button>
      </div>
    </div>
  </div>

  <div class="form-modal" id="tourModal">
    <form class="form-card" id="tourForm">
      <h2 id="tourModalTitle">Thêm tour</h2>
      <input type="hidden" id="tourId" />
      <div class="form-grid">
        <div class="form-group"><label>Tên tour</label><input id="tourName" required /></div>
        <div class="form-group"><label>Tài khoản</label><select id="tourSalesName" required><option value="">Chọn tài khoản</option></select></div>
        <div class="form-group"><label>Điểm đến</label><input id="tourDestination" /></div>
        <div class="form-group"><label>Thời lượng</label><input id="tourDuration" /></div>
        <div class="form-group"><label>Từ ngày</label><input id="tourStartDate" type="date" /></div>
        <div class="form-group"><label>Đến ngày</label><input id="tourEndDate" type="date" /></div>
        <div class="form-group"><label>Giá</label><input id="tourPrice" type="number" min="0" step="1000" /></div>
        <div class="form-group"><label>Tổng chỗ</label><input id="tourSlots" type="number" min="0" /></div>
        <div class="form-group"><label>Đã bán</label><input id="tourSold" type="number" min="0" /></div>
        <div class="form-group"><label>Trạng thái</label><select id="tourStatus"><option>Đang bán</option><option>Tạm dừng</option><option>Đã bán</option></select></div>
        <div class="form-group full"><label>Ảnh URL</label><div class="image-url-field"><input id="tourImage" placeholder="/main_site_image/back1.png hoặc link ảnh" /><button class="image-upload-icon" id="tourImageUploadButton" type="button" title="Đính kèm tệp ảnh" aria-label="Đính kèm tệp ảnh">📎</button><input id="tourImageFile" type="file" accept="image/*" hidden /></div><small class="form-help" id="tourImageFileName"></small></div>
        <div class="form-group full"><label>Mô tả</label><textarea id="tourDescription" rows="3"></textarea></div>
      </div>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closeTourModal()">Đóng</button>
        <button class="btn-primary" type="submit">Lưu tour</button>
      </div>
    </form>
  </div>

  <div class="form-modal" id="planStatusOptionModal">
    <form class="form-card" id="planStatusOptionForm">
      <h2>Sửa trạng thái kế hoạch</h2>
      <input type="hidden" id="planStatusOptionOriginalKey" />
      <input type="hidden" id="planStatusOptionKey" />
      <div class="form-grid">
        <div class="form-group"><label>Tên hiển thị</label><input id="planStatusOptionLabel" placeholder="Đi biển" required /></div>
        <div class="form-group"><label>Hiển thị</label><select id="planStatusOptionEnabled"><option value="true">Hiện</option><option value="false">Ẩn</option></select></div>
        <div class="form-group"><label>Thứ tự</label><input id="planStatusOptionOrder" type="number" min="1" value="999" /></div>
        <div class="form-group"><label>Màu trạng thái</label><input id="planStatusOptionColor" type="color" value="#6366f1" /></div>
        <div class="form-group full"><label>Tag áp dụng</label><div class="tag-checkbox-grid" id="planStatusTagCheckboxes"></div></div>
        <div class="form-group full account-lock-group">
          <label class="account-lock-toggle" for="planStatusOptionMatchAll">
            <input id="planStatusOptionMatchAll" type="checkbox" />
            <span class="account-lock-box" aria-hidden="true"></span>
            <span class="account-lock-text">Bắt buộc khớp tất cả tag</span>
          </label>
        </div>
        <div class="form-group full"><label>Mô tả</label><textarea id="planStatusOptionDescription" rows="3"></textarea></div>
      </div>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closePlanStatusOptionModal()">Đóng</button>
        <button class="btn-primary" type="submit">Lưu trạng thái</button>
      </div>
    </form>
  </div>

  <div class="form-modal" id="travelTagModal">
    <form class="form-card" id="travelTagForm">
      <h2>Thêm tag du lịch</h2>
      <div class="form-grid">
        <div class="form-group"><label>Tên tag</label><input id="travelTagName" placeholder="Ví dụ: ẩm thực" required /></div>
        <div class="form-group"><label>Màu tag</label><input id="travelTagColor" type="color" value="#6366f1" /></div>
        <div class="form-group full"><label>Tag hiện có</label><div class="admin-existing-tag-list" id="travelTagExistingList"></div></div>
      </div>
      <div class="modal-actions">
        <button class="btn-soft" type="button" onclick="closeTravelTagModal()">Đóng</button>
        <button class="btn-primary" type="submit">Lưu tag</button>
      </div>
    </form>
  </div>

  <div class="form-modal" id="provinceTagModal">
    <form class="form-card" id="provinceTagForm">
      <h2>Sửa thông tin tỉnh thành</h2>
      <input type="hidden" id="provinceTagId" />
      <input type="hidden" id="provinceTagProvinceId" />
      <div class="form-grid">
        <div class="form-group"><label>Tỉnh/thành</label><input id="provinceTagName" required /></div>
        <div class="form-group"><label>Khu vực</label><input id="provinceTagArea" /></div>
        <div class="form-group"><label>Vùng</label><input id="provinceTagRegion" /></div>
        <div class="form-group full"><label>Tag du lịch</label><div class="tag-checkbox-grid" id="provinceTagCheckboxes"></div></div>
        <div class="form-group full"><label>Mô tả</label><textarea id="provinceTagDescription" rows="3"></textarea></div>
      </div>
      <div class="modal-actions">
