@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hồ sơ người dùng - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
    <link rel="stylesheet" href="/css/main_site_style.css?v=2026-06-28-chatbot-local-manager-v32" />
    <link rel="stylesheet" href="/css/travelwai_nav_contact.css?v=2026-06-28-chatbot-local-manager-v32" />
    <link rel="stylesheet" href="/css/profile_style.css?v=2026-06-28-chatbot-local-manager-v32" />
  <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-06-28-chatbot-local-manager-v32" />
  </head>
  <body class="profile-page">
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    @await Html.PartialAsync("~/Views/Shared/_TravelwAINav.cshtml", "profile")

    <main class="profile-shell">
      <section class="profile-hero">
        <div>
          <span class="eyebrow">Tài khoản TravelwAI</span>
          <h1>Hồ sơ người dùng</h1>
          
        </div>
        <div class="profile-hero-badge">
          <span>Đang đăng nhập</span>
          <strong id="profileHeroName">TravelwAI</strong>
        </div>
      </section>

      <section class="profile-grid">
        <article class="profile-card profile-summary-card">
          <div class="profile-picture-section">
            <div class="profile-picture-container">
              <img
                id="profilePicture"
                src="/logo/profile-icon-white.png"
                alt="Ảnh đại diện"
                class="profile-picture"
              />
              <button
                type="button"
                class="profile-picture-overlay"
                onclick="document.getElementById('profilePictureInput').click()"
                aria-label="Đổi ảnh đại diện"
              >
                <span>📷</span>
              </button>
            </div>
            <input
              type="file"
              id="profilePictureInput"
              accept="image/*"
              hidden
            />
            <button
              type="button"
              onclick="document.getElementById('profilePictureInput').click()"
              class="upload-btn file-icon-button profile-file-icon-button"
              title="Đổi ảnh đại diện"
              aria-label="Đổi ảnh đại diện"
            >
              📷
            </button>
          </div>

          <div class="profile-name-block">
            <h2 id="profileDisplayName">Đang tải...</h2>
            <p id="profileEmailText">Đang tải thông tin tài khoản</p>
          </div>
        </article>

        <article class="profile-card profile-detail-card">
          <div class="profile-card-header">
            <div>
              <h2>Chi tiết tài khoản</h2>
            </div>
          </div>

          <div class="profile-info">
            <div class="profile-field">
              <div class="field-icon">✉️</div>
              <div>
                <label>Email</label>
                <span id="userEmail">Đang tải...</span>
              </div>
            </div>
            <div class="profile-field">
              <div class="field-icon">👤</div>
              <div>
                <label>Tên người dùng</label>
                <span id="username">Đang tải...</span>
              </div>
            </div>
            <div class="profile-field">
              <div class="field-icon">📅</div>
              <div>
                <label>Ngày tạo tài khoản</label>
                <span id="createdAt">Đang tải...</span>
              </div>
            </div>
            <div class="profile-field">
              <div class="field-icon">💎</div>
              <div>
                <label>Gói đã đăng ký</label>
                <span id="profilePlanRole">Đang tải...</span>
              </div>
            </div>
            <div class="profile-field">
              <div class="field-icon">⏳</div>
              <div>
                <label>Thời hạn gói</label>
                <span id="profilePlanExpiresAt">Đang tải...</span>
              </div>
            </div>
          </div>

          <div class="profile-actions">
            <button
              type="button"
              onclick="window.location.href='/home'"
              class="back-btn"
            >
              Về trang chủ
            </button>
            <button type="button" onclick="openProfilePasswordModal()" class="password-btn">Đổi mật khẩu</button>
            <button type="button" onclick="logout()" class="logout-btn">Đăng xuất</button>
          </div>
        </article>
      </section>
    </main>


    <div class="profile-password-modal" id="profilePasswordModal" hidden>
      <div class="profile-password-backdrop" onclick="closeProfilePasswordModal()"></div>
      <form class="profile-password-card" id="profilePasswordForm" onclick="event.stopPropagation()">
        <button type="button" class="profile-password-close" onclick="closeProfilePasswordModal()" aria-label="Đóng">×</button>
        <div class="profile-password-logo">
          <img src="/logo/travelwai-paper-plane.png" alt="TravelwAI" />
          <strong>TravelwAI</strong>
        </div>
        <p class="auth-kicker">Bảo mật tài khoản</p>
        <h2>Tạo mật khẩu mới</h2>
        <div class="profile-password-fields">
          <input id="profileNewPassword" type="password" placeholder="Mật khẩu mới" autocomplete="new-password" required />
          <input id="profileConfirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" required />
        </div>
        <div class="profile-password-actions">
          <button type="button" class="profile-password-cancel" onclick="closeProfilePasswordModal()">Hủy</button>
          <button type="submit" class="profile-password-submit">Lưu mật khẩu</button>
        </div>
      </form>
    </div>

    <div class="profile-toast" id="profileToast" hidden></div>

    <script src="/script/accounts.js?v=2026-06-28-chatbot-local-manager-v32"></script>
    <script src="/script/image_upload_optimizer.js?v=2026-06-28-chatbot-local-manager-v32"></script>
    <script src="/script/profile_script.js?v=2026-06-28-chatbot-local-manager-v32"></script>
    <script src="/script/travelwai_contact_panel.js?v=2026-06-28-chatbot-local-manager-v32"></script>
    <script src="/script/travelwai_notification_panel.js?v=2026-06-28-chatbot-local-manager-v32"></script>
      <script src="/script/theme_toggle.js?v=2026-06-28-chatbot-local-manager-v32"></script>
</body>
</html>

