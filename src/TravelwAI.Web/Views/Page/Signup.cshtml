@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
    <link rel="stylesheet" href="css/login_signup_style.css?v=2026-06-29-guide-normal-v41" />
  <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-06-29-guide-normal-v41" />
  </head>
  <body>
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    <h1 class="title">
      <a class="brand-home-link" href="/landing" aria-label="Về Landing Page TravelwAI">
        <img
          src="/logo/travelwai-paper-plane.png"
          alt="TravelwAI Logo"
          style="height: 50px; margin-right: 10px"
        />
        <span>TravelwAI</span>
      </a>
    </h1>

    <div class="container">
      <div class="login-container signup-auth-card">
        <h2 class="login-title">Đăng ký</h2>
        <form class="login-form signup-form" onsubmit="handleSignUp(event)">
          <input type="text" id="username" placeholder="Tên người dùng" required />
          <input type="email" id="email" placeholder="Email" required />
          <input type="text" id="offerInvite" placeholder="Mã mời (không bắt buộc)" autocomplete="off" />
          <input type="password" id="password" placeholder="Mật khẩu" required />
          <input
            type="password"
            id="confirm-password"
            placeholder="Nhập lại mật khẩu"
            required
          />
          <button type="submit" class="login-btn signup-btn">Tạo tài khoản</button>
        </form>
        <p class="signup-text">
          Đã có tài khoản?
          <a href="/login" class="signup-link">Đăng nhập</a>
        </p>
      </div>

      <div class="photos-container">
        <div class="polaroid" style="transform: rotate(-6deg)">
          <img src="login_signup_image/2.png" alt="Hà Nội" />
        </div>
        <div class="polaroid featured" style="z-index: 3">
          <img src="login_signup_image/1.png" alt="Sài Gòn" />
        </div>
        <div class="polaroid" style="transform: rotate(5deg)">
          <img src="login_signup_image/3.png" alt="Đà Nẵng" />
        </div>
      </div>
    </div>
    <script src="script/accounts.js?v=2026-06-29-guide-normal-v41"></script>
      <script src="/script/travelwai_guide_chatbot.js?v=2026-06-29-guide-normal-v41"></script>
<script src="/script/theme_toggle.js?v=2026-06-29-guide-normal-v41"></script>
</body>
</html>

