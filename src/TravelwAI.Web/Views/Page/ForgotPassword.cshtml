@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - TravelwAI</title>
    <link rel="icon" href="/logo/travelwai-paper-plane.png" type="image/png" />
    <link rel="stylesheet" href="/css/login_signup_style.css?v=2026-07-01-clean-v1" />
    <link rel="stylesheet" href="/css/travelwai_font.css?v=2026-07-02-rag-v1" />
  </head>
  <body>
    @await Html.PartialAsync("~/Views/Shared/_TravelwAIFloatingTools.cshtml")
    <h1 class="title">
      <a class="brand-home-link" href="/landing" aria-label="Về Landing Page TravelwAI">
        <img
          src="/logo/travelwai-paper-plane.png"
          alt="TravelwAI Logo"
          style="height: 50px; margin-right: 10px"
        />
        <span>TravelwAI</span>
      </a>
    </h1>

    <div class="container">
      <div class="login-container password-reset-card">
        <p class="auth-kicker">Bảo mật tài khoản</p>
        <h2 class="login-title">Xác nhận đổi mật khẩu</h2>
        
        <form class="login-form" id="requestResetOtpForm" onsubmit="handleForgotPassword(event)">
          <input
            type="email"
            id="email"
            placeholder="Nhập email của bạn"
            required
          />
          <button type="submit" class="login-btn">Gửi mã OTP</button>
          <p class="auth-help-text">Chưa nhận được mã? Bấm lại nút Gửi mã OTP để gửi lại.</p>
        </form>

        <form class="login-form otp-form" id="verifyResetOtpForm" onsubmit="handleVerifyPasswordResetOtp(event)" hidden>
          <input
            type="text"
            id="resetOtp"
            inputmode="numeric"
            maxlength="6"
            placeholder="Nhập mã OTP 6 số"
            required
          />
          <button type="submit" class="login-btn">Xác nhận OTP</button>
        </form>

        <p class="auth-message" id="authMessage" hidden></p>

        <p class="login-text">
          Đã nhớ mật khẩu?
          <a href="/login" class="login-link">Đăng nhập</a>
        </p>
      </div>
      <div class="photos-container">
        <div class="polaroid" style="transform: rotate(-6deg)">
          <img src="/login_signup_image/2.png" alt="Hà Nội" />
        </div>
        <div class="polaroid featured" style="z-index: 3">
          <img src="/login_signup_image/1.png" alt="Sài Gòn" />
        </div>
        <div class="polaroid" style="transform: rotate(5deg)">
          <img src="/login_signup_image/3.png" alt="Đà Nẵng" />
        </div>
      </div>
    </div>
    <script src="/script/accounts.js?v=2026-07-01-clean-v1"></script>
<script src="/script/theme_toggle.js?v=2026-07-02-rag-v1"></script>
</body>
</html>

